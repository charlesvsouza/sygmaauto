DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sygmaauto?schema=public"
JWT_SECRET="sygmaauto-secret-key-change-in-production"
JWT_REFRESH_SECRET="sygmaauto-refresh-secret-change-in-production"
FRONTEND_URL="https://sigmaauto.com.br"
CORS_ORIGINS="https://sigmaauto.com.br,https://www.sigmaauto.com.br,http://localhost:5173,http://localhost:5174,http://localhost:5175"
PORT=3000
NODE_ENV="production"
# Mercado Pago
MP_ACCESS_TOKEN=""
MP_MODE="production"
MP_WEBHOOK_SECRET=""
# Opcional: token adicional enviado no header x-webhook-token
MP_WEBHOOK_TOKEN=""
# Opcional: URL pública do webhook; se vazio, usa BACKEND_PUBLIC_URL/RAILWAY_PUBLIC_DOMAIN
MP_WEBHOOK_URL=""
# URL pública do backend para compor callback de webhook automaticamente
BACKEND_PUBLIC_URL=""
# Origens permitidas para success/cancel URL do checkout (separadas por vírgula)
CHECKOUT_ALLOWED_RETURN_ORIGINS="https://sigmaauto.com.br,https://www.sigmaauto.com.br"
CHECKOUT_SUCCESS_URL="https://sigmaauto.com.br/settings?checkout=success"
CHECKOUT_CANCEL_URL="https://sigmaauto.com.br/settings?checkout=cancel"
# Emails institucionais (utilizados em seed e comunicações)
SUPPORT_EMAIL="suporte@sigmaauto.com.br"
CONTACT_EMAIL="contato@sigmaauto.com.br"
SALES_EMAIL="assine@sigmaauto.com.br"
GENERAL_EMAIL="sigmaauto@sigmaauto.com.br"
# Seed de usuários padrão
SEED_SUPERADMIN_EMAIL="sigmaauto@sigmaauto.com.br"
SEED_SUPERADMIN_NAME="Sigma Auto Super Admin"
SEED_SUPERADMIN_PASSWORD=""
SEED_TENANT_OWNER_EMAIL="assine@sigmaauto.com.br"
SEED_TENANT_OWNER_NAME="Master Sigma Auto"
SEED_TENANT_OWNER_CONTACT_EMAIL="assine@sigmaauto.com.br"
SEED_MASTER_PASSWORD=""
# Segurança: mantenha false em produção
ALLOW_INTERNAL_PLAN_CHANGE="false"
# Defina uma das chaves abaixo para importação de PDF com IA
GOOGLE_API_KEY=""
