generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enum para definir os níveis de acesso
enum WorkshopArea {
  MECANICA
  ELETRICA
  FUNILARIA_PINTURA
  LAVACAO
  HIGIENIZACAO_EMBELEZAMENTO
}

enum JobFunction {
  MECANICO
  ELETRICISTA
  APRENDIZ
  PINTOR
  PREPARADOR
  COLABORADOR_SERVICOS_GERAIS
  FUNILEIRO
  LAVADOR
  MARTELINHO_OURO
  EMBELEZADOR_AUTOMOTIVO
  CHEFE_OFICINA
}

enum UserRole {
  MASTER      // Proprietário - 1 por tenant, acesso total
  ADMIN       // Gerenciador - cria equipe, configura a oficina
  GERENTE     // Gerência operacional - aprova OSs, visualiza relatórios
  CHEFE_OFICINA // Liderança técnica por área, com equipe delegada
  FINANCEIRO  // Financeiro/Cobrança - fecha OS e registra pagamentos
  SECRETARIA  // Recepção - abre OS, cadastra clientes e veículos
  MECANICO    // Mecânico/Técnico - executa OS, adiciona peças e serviços
  PRODUTIVO   // Legado — equivalente a MECANICO (mantido para compatibilidade)
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  status    String   @default("ACTIVE")
  document  String   @unique
  taxId     String?  // CNPJ, MEI or CPF
  companyType String @default("CNPJ") // CNPJ, MEI, CPF
  legalNature String @default("PJ") // PF or PJ
  legalName   String?
  tradeName   String?
  stateRegistration String?
  municipalRegistration String?
  address   String?

  phone     String?
  email     String?
  setupInviteEmail String?
  setupInviteToken String? @unique
  setupInviteExpiresAt DateTime?
  setupCompletedAt DateTime?
  logo            String?
  laborHourlyRate Float?   @default(120)
  diagnosticHours Float?   @default(0.5)  // horas padrão para serviço de diagnóstico
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscription          Subscription?
  users                 User[]
  customers             Customer[]
  vehicles              Vehicle[]
  serviceOrders         ServiceOrder[]
  servicesCatalog       Service[]
  parts                 Part[]
  suppliers             Supplier[]
  inventoryMovements    InventoryMovement[]
  financialTransactions FinancialTransaction[]
  messages              Message[]
  auditLogs             AuditLog[]
  checklists            VehicleChecklist[]
  commissions           Commission[]
  commissionRates       CommissionRate[]

  @@map("tenants")
}

model SubscriptionPlan {
  id          String   @id @default(uuid())
  name        String @unique
  description String?
  price       Float
  features    String
  limits      String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id            String             @id @default(uuid())
  tenantId      String             @unique
  planId        String
  status       String @default("TRIALING")
  startedAt    DateTime           @default(now())
  currentPeriodStart DateTime     @default(now())
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd   Boolean      @default(false)
  trialEndsAt   DateTime?
  
  // Quotas de O.S. mensal
  osCreatedThisMonth    Int       @default(0)  // Contador de O.S. criadas neste mês
  osMonthResetDate      DateTime  @default(now())  // Data do último reset (1º do mês)
  
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model SuperAdmin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("super_admins")
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  email        String
  recoveryEmail String?
  passwordHash String
  passwordResetToken String?
  passwordResetExpiresAt DateTime?
  passwordUpdatedAt DateTime?
  name         String
  role         UserRole @default(PRODUTIVO)
  invitedBy    String?  // Email de quem convidou (auditoria)
  isActive     Boolean  @default(true)
  workshopArea WorkshopArea?
  jobFunction  JobFunction?
  lastLoginAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  serviceOrders    ServiceOrder[]
  timeline         ServiceOrderTimeline[]
  assignedItems    ServiceOrderItem[]  @relation("AssignedItems")
  commissions      Commission[]        @relation("UserCommissions")
  commissionRate   CommissionRate?     @relation("UserCommissionRate")

  @@unique([tenantId, email])
  @@map("users")
}

model Customer {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  document  String?
  rg        String?
  nacionalidade String?
  estado_civil  String?
  profissao     String?
  email     String?
  phone     String?
  cep       String?
  address   String?
  cidade    String?
  estado    String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  vehicles      Vehicle[]
  serviceOrders ServiceOrder[]

  @@map("customers")
}

model Vehicle {
  id          String   @id @default(uuid())
  tenantId    String
  customerId  String
  plate       String
  brand       String
  model       String
  year        Int?
  color       String?
  vin         String?
  km         Int?
  notes       String?

  // Manutenção Preventiva
  lastMaintenanceKm      Int?
  lastMaintenanceDate    DateTime?
  maintenanceIntervalKm  Int?       // Ex: 10000 (a cada 10.000 km)
  maintenanceIntervalDays Int?      // Ex: 180 (a cada 6 meses)
  reminderSentAt         DateTime?  // Última vez que o lembrete foi enviado

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  customer       Customer       @relation(fields: [customerId], references: [id])
  serviceOrders  ServiceOrder[]

  @@unique([tenantId, plate])
  @@map("vehicles")
}

model Service {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  basePrice   Float
  category    String?
  duration    Int?
  isActive    Boolean  @default(true)
  hourlyRate  Float?   // VH - Valor Hora
  tmo         Float?   // Tempo de Mão de Obra (em horas decimais)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant        Tenant             @relation(fields: [tenantId], references: [id])
  serviceItems ServiceOrderItem[]

  @@map("services")
}


model Supplier {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  document    String?
  phone       String?
  email       String?
  contactName String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  parts  Part[]

  @@map("suppliers")
}

model Part {
  id           String   @id @default(uuid())
  tenantId     String
  name         String
  internalCode String?
  sku          String?
  description  String?
  category     String?
  unitPrice    Float
  costPrice    Float?
  unit         String   @default("un")
  minStock     Int      @default(0)
  currentStock Int      @default(0)
  location     String?
  supplierId   String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  supplier           Supplier?          @relation(fields: [supplierId], references: [id])
  serviceItems       ServiceOrderItem[]
  inventoryMovements InventoryMovement[]

  @@unique([tenantId, sku])
  @@map("parts")
}

model ServiceOrder {
  id              String            @id @default(uuid())
  tenantId        String
  customerId     String
  vehicleId      String
  orderType      String         @default("ORCAMENTO")
  status         String         @default("ORCAMENTO")
  complaint      String?
  diagnosis     String?
  technicalReport String?
  observations   String?
  
  // Equipamento (Automóvel ou outro)
  equipmentBrand  String?
  equipmentModel  String?
  serialNumber    String?

  
  // KM do veículo
  kmEntrada     Int?
  kmSaida       Int?
  kmDiferenca   Int? // Calculado: kmSaida - kmEntrada
  testeRodagem  Boolean @default(false) // Indica se houve teste de rodagem
  
  // Aprovação
  approvalToken  String?
  approvalStatus  String?
  approvalTokenExpires DateTime?
  approvedAt    DateTime?
  approvedBy   String?
  
  // Controle de Fluxo
  reserveStock      Boolean   @default(false)
  diagnosticCost    Float     @default(0)

  // Rastreamento de tempo por status (Opção B — alertas precisos no Kanban)
  statusChangedAt   DateTime?

  // Reserva / Pedido de Peças
  partsReserved       Boolean   @default(false)
  partsCheckedAt      DateTime?
  expectedPartsDate   DateTime?
  purchaseOrderNumber String?
  
  // Valores

  totalParts     Float           @default(0)
  totalServices  Float           @default(0)
  totalLabor   Float           @default(0)
  totalDiscount Float         @default(0)
  totalCost    Float           @default(0)

  
  // Datas
  scheduledDate  DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  deliveredAt  DateTime?
  paidAt      DateTime?
  
  // Informações
  notes        String?
  paymentMethod String?
  mechanicId  String?
  mechanic   User?             @relation(fields: [mechanicId], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tenant      Tenant                 @relation(fields: [tenantId], references: [id])
  customer    Customer               @relation(fields: [customerId], references: [id])
  vehicle     Vehicle                @relation(fields: [vehicleId], references: [id])
  items       ServiceOrderItem[]
  timeline    ServiceOrderTimeline[]
  checklists  VehicleChecklist[]
  commissions Commission[]

  @@map("service_orders")
}

model ServiceOrderItem {
  id              String   @id @default(uuid())
  serviceOrderId  String
  serviceId       String?
  partId          String?
  assignedUserId  String?
  description     String
  quantity        Float    @default(1)
  unitPrice       Float
  totalPrice      Float
  discount        Float    @default(0)

  type            String
  applied         Boolean  @default(false)
  createdAt       DateTime @default(now())

  serviceOrder ServiceOrder  @relation(fields: [serviceOrderId], references: [id])
  service      Service?      @relation(fields: [serviceId], references: [id])
  part         Part?         @relation(fields: [partId], references: [id])
  assignedUser User?         @relation("AssignedItems", fields: [assignedUserId], references: [id])
  commission   Commission?

  @@map("service_order_items")
}

model ServiceOrderTimeline {
  id             String   @id @default(uuid())
  serviceOrderId String
  status         String
  eventType     String   @default("status") // status, payment, stock, note
  description    String?
  createdBy      String?
  creator       User?       @relation(fields: [createdBy], references: [id])
  createdAt      DateTime @default(now())

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id])

  @@map("service_order_timeline")
}

model InventoryMovement {
  id        String       @id @default(uuid())
  tenantId  String
  partId   String
  type     String
  quantity Int
  note     String?
  createdAt DateTime     @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  part   Part   @relation(fields: [partId], references: [id])

  @@map("inventory_movements")
}

model FinancialTransaction {
  id          String          @id @default(uuid())
  tenantId    String
  type        String
  amount      Float
  description String?
  category    String?
  referenceId String?
  referenceType String?
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("financial_transactions")
}

model Message {
  id         String   @id @default(uuid())
  tenantId   String
  type       String
  to         String
  channel   String
  subject    String?
  body      String
  status    String   @default("pending")
  sentAt    DateTime?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("messages")
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String?
  entityType String
  entityId   String
  action     String
  changes    String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("audit_logs")
}

// ────────────────────────────────────────────
// Checklist de Entrada/Saída de Veículo
// ────────────────────────────────────────────

model VehicleChecklist {
  id             String    @id @default(uuid())
  tenantId       String
  serviceOrderId String
  type           String    // ENTRADA | SAIDA
  fuelLevel      Int       @default(0) // 0-8 (oitavos do tanque)
  observations   String?
  completedAt    DateTime?
  completedBy    String?   // nome do responsável pela vistoria (mecânico/recepcionista)
  ownerName      String?   // nome de quem entregou/retirou o veículo
  ownerType      String?   @default("PROPRIETARIO") // PROPRIETARIO | DELEGADO
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  items        ChecklistItem[]

  @@unique([serviceOrderId, type])
  @@map("vehicle_checklists")
}

model ChecklistItem {
  id          String   @id @default(uuid())
  checklistId String
  area        String   // CAPO, TETO, PORTA_LD_DIANT, etc.
  condition   String   // OK | RISCO | AMASSADO | QUEBRADO | AUSENTE
  notes       String?
  createdAt   DateTime @default(now())

  checklist VehicleChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  photos    ChecklistPhoto[]

  @@map("checklist_items")
}

model ChecklistPhoto {
  id        String   @id @default(uuid())
  itemId    String
  data      String   // base64 ou URL
  mimeType  String   @default("image/jpeg")
  createdAt DateTime @default(now())

  item ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("checklist_photos")
}

// ────────────────────────────────────────────
// Comissões de Mecânicos / Executores
// ────────────────────────────────────────────

model CommissionRate {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String?  @unique
  role      String?
  rate      Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation("UserCommissionRate", fields: [userId], references: [id])

  @@map("commission_rates")
}

model Commission {
  id                 String    @id @default(uuid())
  tenantId           String
  serviceOrderId     String
  serviceOrderItemId String    @unique
  userId             String
  baseValue          Float
  commissionPercent  Float
  commissionValue    Float
  status             String    @default("PENDENTE")
  paidAt             DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  serviceOrder     ServiceOrder     @relation(fields: [serviceOrderId], references: [id])
  serviceOrderItem ServiceOrderItem @relation(fields: [serviceOrderItemId], references: [id])
  user             User             @relation("UserCommissions", fields: [userId], references: [id])

  @@map("commissions")
}
